KICK_CHANNEL_SLUG=rellaria

# Kanal bilgisi otomatik alınamazsa Kick channel API'sindeki chatroom.id değerini yazın.
KICK_CHATROOM_ID=

# Kick Developer Portal'dan alınan OAuth 2.1 bilgileri
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=

# OAuth PKCE flow ile alınan bot token'ı (otomatik set edilir, elle de girilebilir)
KICK_BOT_TOKEN=

# Kick Pusher altyapısı değişirse buradan güncellenebilir.
KICK_PUSHER_URL=wss://ws-us2.pusher.com/app/32cbd69e4b950bf97679

# Render.com gibi platformlarda canlı alan adını belirtin (sonunda / olmadan)
PUBLIC_BASE_URL=

PORT=3000
CLIENT_ORIGIN=*
